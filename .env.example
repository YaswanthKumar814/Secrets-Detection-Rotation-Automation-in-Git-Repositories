# GitGuard optional AWS configuration (all disabled by default)
# Copy to .env and adjust for local development or LocalStack testing.

GITGUARD_AWS_ENABLED=false
GITGUARD_AWS_REGION=ap-south-1
# For LocalStack: http://localhost:4566
GITGUARD_AWS_ENDPOINT_URL=
GITGUARD_S3_BUCKET=
GITGUARD_DYNAMODB_TABLE=
GITGUARD_SNS_TOPIC_ARN=
GITGUARD_ALLOW_REAL_AWS_VALIDATION=false

# Repository ingestion (Phase 2)
GITGUARD_ALLOWLIST_PATH=
GITGUARD_ENFORCE_ALLOWLIST=false
GITGUARD_CLONE_DEPTH=1
GITGUARD_CLONE_TIMEOUT_SEC=120
